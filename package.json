{
  "name": "deep-gait",
  "private": true,
  "workspaces": [
    "webapp/server",
    "webapp/client"
  ],
  "scripts": {
    "start:server": "npm run start -w deepgait-server",
    "dev:server": "npm run dev -w deepgait-server",
    "dev:client": "npm run dev -w deepgait-client",
    "build:client": "npm run build -w deepgait-client",
    "dev:all": "concurrently -k -n server,client -c cyan,magenta \"npm run start:server\" \"npm run dev:client\"",
    "run:all": "bash scripts/run-all.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
