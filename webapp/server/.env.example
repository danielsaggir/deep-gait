PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/deepgait
# Absolute path to project root (contains config.yaml and src/ml)
REPO_ROOT=/absolute/path/to/Deep Gait
PYTHON_BIN=python3
# Weights file to load for uploads/match (inference only — the server never runs training).
# Relative paths are under REPO_ROOT. Use your last saved .pth, e.g. models/checkpoint.pth
CHECKPOINT_PATH=models/checkpoint.pth
